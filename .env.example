# Stellar Network (testnet | mainnet)
STELLAR_NETWORK=testnet

# Server wallet - receives payments
# Generate at: https://lab.stellar.org
MPP_SECRET_KEY=S...
STELLAR_RECIPIENT=G...

# Agent wallet - pays for services
AGENT_SECRET_KEY=S...

# Optional: Brave Search API key (https://api.search.brave.com)
# Without this, falls back to Jina AI (free, no key needed)
BRAVE_API_KEY=

# Optional: x402 facilitator (default: Coinbase's managed facilitator)
X402_FACILITATOR_URL=https://www.x402.org/facilitator

# Agent budget in USDC (default: 0.10)
AGENT_BUDGET=0.10

# Server URL (for agent to call)
SERVER_URL=http://localhost:3000


# AI inference — priority: Gemini → OpenRouter → mock
# Gemini: aistudio.google.com (free tier available)
GEMINI_API_KEY=your_gemini_api_key_here
# OpenRouter fallback if Gemini quota is exhausted: openrouter.ai
OPENROUTER_API_KEY=