# Stellar Network (testnet | mainnet)
STELLAR_NETWORK=testnet

# Server wallet - receives payments
# Generate at: https://lab.stellar.org
MPP_SECRET_KEY=S...
STELLAR_RECIPIENT=G...

# Agent wallet - pays for services
AGENT_SECRET_KEY=S...

# Optional: Brave Search API key (https://api.search.brave.com)
# Without this, falls back to Jina AI (free, no key needed)
BRAVE_API_KEY=

# Server URL (for agent to call)
SERVER_URL=http://localhost:3000


# Get a free key at console.groq.com — no credit card needed.
GROQ_API_KEY=your_actual_groq_key_here